{
  "name": "geoalgeria-monorepo",
  "private": true,
  "description": "GeoAlgeria data monorepo — the geoalgeria dataset + @geoalgeria/poste",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "validate": "pnpm --filter ./packages/dataset validate",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm validate && changeset publish",
    "release-staged": "pnpm validate && node scripts/stage-publish.js"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0"
  }
}
