{
  "name": "@geoalgeria/emploi",
  "version": "1.0.0",
  "type": "module",
  "description": "Algeria public employment agencies — 58 AWEM (wilaya) + 273 ALEM (local) offices with address, phone, manager, communes served, and coordinates. Sourced from ANEM (anem.dz). JSON, CSV, GeoJSON.",
  "main": "index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./index.js"
    },
    "./data/*": "./data/*"
  },
  "files": [
    "data/**/*.json",
    "types/",
    "index.js"
  ],
  "scripts": {
    "fetch": "node scripts/fetch.mjs"
  },
  "keywords": [
    "algeria",
    "employment",
    "emploi",
    "anem",
    "awem",
    "alem",
    "agence-emploi",
    "job-center",
    "geojson",
    "geoalgeria",
    "dz"
  ],
  "author": "Yasser's Studio (https://yasser.studio)",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/yasserstudio/geoalgeria/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yasserstudio/geoalgeria.git",
    "directory": "packages/emploi"
  },
  "homepage": "https://geoalgeria.com",
  "engines": {
    "node": ">=18"
  }
}
