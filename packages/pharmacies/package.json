{
  "name": "@geoalgeria/pharmacies",
  "version": "1.0.0",
  "type": "module",
  "description": "Algeria's pharmacies (officines) from OpenStreetMap — geocoded, bilingual FR/AR where named, with phone/opening-hours/dispensing where tagged and wilaya/commune linkage against the geoalgeria commune set. JSON, CSV, GeoJSON, TypeScript.",
  "main": "index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./index.js"
    },
    "./data/*": "./data/*"
  },
  "files": [
    "data/**/*.json",
    "data/**/*.csv",
    "data/**/*.geojson",
    "types/",
    "index.js"
  ],
  "devDependencies": {
    "@geoalgeria/schema": "workspace:^"
  },
  "scripts": {
    "fetch": "node scripts/fetch.mjs",
    "test": "node ../../scripts/validate-packages.mjs pharmacies"
  },
  "keywords": [
    "algeria",
    "pharmacies",
    "pharmacy",
    "officine",
    "pharmacie",
    "صيدلية",
    "health",
    "openstreetmap",
    "osm",
    "geojson",
    "geoalgeria",
    "dz"
  ],
  "author": "Yasser's Studio (https://yasser.studio)",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/yasserstudio/geoalgeria/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yasserstudio/geoalgeria.git",
    "directory": "packages/pharmacies"
  },
  "homepage": "https://geoalgeria.com",
  "engines": {
    "node": ">=18"
  }
}
