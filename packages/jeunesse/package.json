{
  "name": "@geoalgeria/jeunesse",
  "version": "1.0.0",
  "type": "module",
  "description": "Algeria's 2,076 youth & sports institutions — maisons de jeunes, complexes sportifs, auberges de jeunes, cultural centers & more, with type, commune/wilaya linkage and GPS coordinates. Sourced from the Ministère de la Jeunesse. JSON, CSV, GeoJSON, TypeScript.",
  "main": "index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./index.js"
    },
    "./data/*": "./data/*"
  },
  "files": [
    "data/**/*.json",
    "types/",
    "index.js"
  ],
  "scripts": {
    "fetch": "node scripts/fetch.mjs",
    "test": "node ../../scripts/validate-packages.mjs jeunesse"
  },
  "keywords": [
    "algeria",
    "jeunesse",
    "youth",
    "sports",
    "maison-de-jeunes",
    "auberge-de-jeunesse",
    "complexe-sportif",
    "mjeunesse",
    "institutions",
    "geojson",
    "geoalgeria",
    "algerie",
    "dz",
    "open-data"
  ],
  "author": "Yasser's Studio (https://yasser.studio)",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/yasserstudio/geoalgeria/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yasserstudio/geoalgeria.git",
    "directory": "packages/jeunesse"
  },
  "homepage": "https://geoalgeria.com",
  "engines": {
    "node": ">=18"
  }
}
