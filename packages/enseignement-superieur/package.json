{
  "name": "@geoalgeria/enseignement-superieur",
  "version": "1.1.0",
  "type": "module",
  "description": "Algeria's higher-education network — 177 universities, grandes écoles, écoles normales supérieures, centres universitaires, licensed private institutions and establishments under other ministries from the MESRS, with type, sector, supervising ministry, French & Arabic names, official website, wilaya/commune linkage and coordinates. JSON, CSV, GeoJSON, TypeScript.",
  "main": "index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./index.js"
    },
    "./data/*": "./data/*"
  },
  "files": [
    "data/**/*.json",
    "data/**/*.csv",
    "data/**/*.geojson",
    "types/",
    "index.js"
  ],
  "scripts": {
    "fetch": "node scripts/fetch.mjs",
    "geocode": "node scripts/geocode.mjs",
    "test": "node ../../scripts/validate-packages.mjs enseignement-superieur"
  },
  "keywords": [
    "algeria",
    "universities",
    "universites",
    "enseignement-superieur",
    "higher-education",
    "grande-ecole",
    "ecole-normale-superieure",
    "ecole-privee",
    "private-university",
    "mesrs",
    "geojson",
    "geoalgeria",
    "algerie",
    "dz",
    "open-data"
  ],
  "author": "Yasser's Studio (https://yasser.studio)",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/yasserstudio/geoalgeria/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yasserstudio/geoalgeria.git",
    "directory": "packages/enseignement-superieur"
  },
  "homepage": "https://geoalgeria.com",
  "engines": {
    "node": ">=18"
  }
}
