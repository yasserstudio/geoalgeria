{
  "name": "@geoalgeria/tourisme",
  "version": "2.0.0",
  "type": "module",
  "description": "Tourism infrastructure across Algeria's 69 wilayas — 4,300+ geocoded hotels, attractions, historic sites, thermal springs and protected areas. JSON, CSV, GeoJSON, TypeScript.",
  "main": "index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./index.js"
    },
    "./data/*": "./data/*"
  },
  "files": [
    "dataset-metadata.json",
    "data/**/*.json",
    "data/**/*.csv",
    "data/**/*.geojson",
    "types/",
    "index.js"
  ],
  "scripts": {
    "test": "node ../../scripts/validate-packages.mjs tourisme"
  },
  "keywords": [
    "algeria",
    "tourism",
    "tourisme",
    "hotels",
    "attractions",
    "historic",
    "thermal-springs",
    "national-parks",
    "geojson",
    "geoalgeria",
    "algerie",
    "dz",
    "open-data"
  ],
  "author": "Yasser's Studio (https://yasser.studio)",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/yasserstudio/geoalgeria/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yasserstudio/geoalgeria.git",
    "directory": "packages/tourisme"
  },
  "homepage": "https://geoalgeria.com",
  "engines": {
    "node": ">=18"
  }
}
