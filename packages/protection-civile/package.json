{
  "name": "@geoalgeria/protection-civile",
  "version": "2.0.0",
  "type": "module",
  "description": "Algeria's Protection Civile (civil protection / fire & rescue) units — official-primary from the DGPC's own dataset (dgpc.dz): 880 units nationwide, Arabic names, address/phone/fax, status tier, geocoded, with post-2026-reform wilaya linkage. JSON, CSV, GeoJSON, TypeScript.",
  "main": "index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./index.js"
    },
    "./data/*": "./data/*"
  },
  "files": [
    "dataset-metadata.json",
    "data/**/*.json",
    "data/**/*.csv",
    "data/**/*.geojson",
    "types/",
    "index.js"
  ],
  "devDependencies": {
    "@geoalgeria/schema": "workspace:^"
  },
  "scripts": {
    "fetch": "node scripts/fetch.mjs",
    "test": "node ../../scripts/validate-packages.mjs protection-civile"
  },
  "keywords": [
    "algeria",
    "protection civile",
    "civil protection",
    "fire station",
    "fire and rescue",
    "protection-civile",
    "الحماية المدنية",
    "dgpc",
    "emergency",
    "geojson",
    "geoalgeria",
    "dz"
  ],
  "author": "Yasser's Studio (https://yasser.studio)",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/yasserstudio/geoalgeria/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yasserstudio/geoalgeria.git",
    "directory": "packages/protection-civile"
  },
  "homepage": "https://geoalgeria.com",
  "engines": {
    "node": ">=18"
  }
}
