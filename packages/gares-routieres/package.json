{
  "name": "@geoalgeria/gares-routieres",
  "version": "2.0.0",
  "type": "module",
  "description": "Algeria's intercity bus stations (gares routières) — 74 SOGRAL terminals across 51 wilayas with official names, addresses, coordinates, surface areas, and wilaya/commune linkage. Sourced from SOGRAL (live.sogral.com). JSON, CSV, GeoJSON, TypeScript.",
  "main": "index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./index.js"
    },
    "./data/*": "./data/*"
  },
  "files": [
    "dataset-metadata.json",
    "data/**/*.json",
    "data/**/*.csv",
    "data/**/*.geojson",
    "types/",
    "index.js"
  ],
  "scripts": {
    "fetch": "node scripts/fetch.mjs",
    "test": "node ../../scripts/validate-packages.mjs gares-routieres"
  },
  "keywords": [
    "algeria",
    "gare-routiere",
    "gares-routieres",
    "bus",
    "autocar",
    "interurbain",
    "sogral",
    "bus-station",
    "transport",
    "geojson",
    "geoalgeria",
    "dz"
  ],
  "author": "Yasser's Studio (https://yasser.studio)",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/yasserstudio/geoalgeria/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yasserstudio/geoalgeria.git",
    "directory": "packages/gares-routieres"
  },
  "homepage": "https://geoalgeria.com",
  "engines": {
    "node": ">=18"
  }
}
