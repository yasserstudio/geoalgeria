{
  "name": "@geoalgeria/mosquees",
  "version": "1.0.0",
  "type": "module",
  "description": "Mosques of Algeria — 20,000+ geocoded mosques compiled from Wikidata and OpenStreetMap, with Arabic & French names, denomination, commune/wilaya linkage and GPS coordinates. JSON, CSV, GeoJSON, TypeScript.",
  "main": "index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./index.js"
    },
    "./data/*": "./data/*"
  },
  "files": [
    "data/**/*.json",
    "data/**/*.csv",
    "data/**/*.geojson",
    "types/",
    "index.js"
  ],
  "scripts": {
    "fetch": "node scripts/fetch.mjs",
    "test": "node ../../scripts/validate-packages.mjs mosquees"
  },
  "keywords": [
    "algeria",
    "mosques",
    "mosquees",
    "masjid",
    "places-of-worship",
    "religion",
    "wikidata",
    "openstreetmap",
    "geojson",
    "geoalgeria",
    "dz"
  ],
  "author": "Yasser's Studio (https://yasser.studio)",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/yasserstudio/geoalgeria/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yasserstudio/geoalgeria.git",
    "directory": "packages/mosquees"
  },
  "homepage": "https://geoalgeria.com",
  "engines": {
    "node": ">=18"
  }
}
