{
  "name": "@geoalgeria/ooredoo",
  "version": "1.0.0",
  "type": "module",
  "description": "Ooredoo Algérie retail network — Espaces Ooredoo (EO), City Shops (CSO) and Espaces Services (ESO) with real coordinates and wilaya/commune linkage, from the operator's public locator API. Completes the telecom retail trio with @geoalgeria/mobilis and @geoalgeria/djezzy. JSON, CSV, GeoJSON, TypeScript.",
  "main": "index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./index.js"
    },
    "./data/*": "./data/*"
  },
  "files": [
    "dataset-metadata.json",
    "data/**/*.json",
    "data/**/*.csv",
    "data/**/*.geojson",
    "types/",
    "index.js"
  ],
  "scripts": {
    "fetch": "node scripts/fetch.mjs",
    "test": "node ../../scripts/validate-packages.mjs ooredoo"
  },
  "keywords": [
    "algeria",
    "ooredoo",
    "telecom",
    "boutiques",
    "stores",
    "espace-ooredoo",
    "retail",
    "أوريدو",
    "geojson",
    "geoalgeria",
    "dz"
  ],
  "author": "Yasser's Studio (https://yasser.studio)",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/yasserstudio/geoalgeria/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yasserstudio/geoalgeria.git",
    "directory": "packages/ooredoo"
  },
  "homepage": "https://geoalgeria.com",
  "engines": {
    "node": ">=18"
  }
}
